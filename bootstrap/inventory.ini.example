# Generate this from Terraform: cd infra && terraform output ansible_inventory
# Or fill manually after provisioning

[control_plane]
verda-k8s-cp ansible_host=<CP_PUBLIC_IP> ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa

[workers]
verda-k8s-worker-1 ansible_host=<WORKER1_PUBLIC_IP> ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa
verda-k8s-worker-2 ansible_host=<WORKER2_PUBLIC_IP> ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa

[k8s_cluster:children]
control_plane
workers
